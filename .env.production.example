# --- Core Django settings ---------------------------------------------------
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret-key
ALLOWED_HOSTS=example.com,www.example.com,server-ip
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
WAGTAILADMIN_BASE_URL=https://example.com

# If TLS is terminated by an external reverse proxy, keep these enabled.
SECURE_SSL_REDIRECT=False
USE_X_FORWARDED_HOST=True
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# --- Database ---------------------------------------------------------------
POSTGRES_DB=repository
POSTGRES_USER=repository
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://repository:change-me-strong-password@db:5432/repository

# --- Wagtail / Django bootstrap --------------------------------------------
AUTO_MIGRATE=1
AUTO_COLLECTSTATIC=1
AUTO_BOOTSTRAP_WAGTAIL=1
AUTO_ENSURE_MILVUS_COLLECTION=1
RUN_DEPLOY_CHECK=0

# Optional one-time bootstrap of the first admin user.
AUTO_CREATE_SUPERUSER=1
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me-admin-password
DJANGO_SUPERUSER_FULL_NAME=Repository Administrator

# --- Storage paths inside the container ------------------------------------
STATIC_ROOT=/app/staticfiles
MEDIA_ROOT=/app/media

# --- Milvus -----------------------------------------------------------------
MILVUS_URI=http://milvus:19530
MILVUS_COLLECTION=publications_chunks_hybrid_v1
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password

# --- Search / model profile -------------------------------------------------
SEARCH_PROFILE=fast
MILVUS_BGE_M3_MODEL=BAAI/bge-m3
MILVUS_BGE_M3_BATCH_SIZE=64
MILVUS_BGE_M3_DEVICE=cpu
MILVUS_BGE_M3_USE_FP16=False
SEARCH_RERANK_ENABLED=False
SEARCH_RERANK_MODEL=BAAI/bge-reranker-v2-m3
SEARCH_RERANK_DEVICE=cpu
SEARCH_WARMUP_ON_STARTUP=True
SEARCH_WARMUP_INCLUDE_RERANK=False
SEARCH_WARMUP_LOAD_COLLECTION=True

# Optional GPU deployment:
# TORCH_INDEX_URL=https://download.pytorch.org/whl/cu128
# MILVUS_BGE_M3_DEVICE=cuda:0
# SEARCH_RERANK_DEVICE=cuda:0
# MILVUS_BGE_M3_USE_FP16=True
# SEARCH_RERANK_ENABLED=True

# --- Existing prototype tuning knobs (optional; keep defaults if unsure) ---
VECTOR_INDEX_SCHEMA_VERSION=2026-03-structural-retrieval-v1
VECTOR_CHUNK_MAX_WORDS=320
VECTOR_CHUNK_OVERLAP_WORDS=40
VECTOR_CHUNK_MAX_CHARS=2200
VECTOR_HEADING_MAX_WORDS=14
VECTOR_ANCHOR_MAX_CHARS=520
VECTOR_INDEX_INCLUDE_METADATA_ANCHOR=True
VECTOR_INDEX_MAX_EMBED_TEXTS=512
VECTOR_REINDEX_PUBLICATION_BATCH_SIZE=128
VECTOR_REINDEX_CHUNK_BATCH_SIZE=1024

SEARCH_PAGE_SIZE=10
SEARCH_CANDIDATE_POOL_SIZE=120
SEARCH_EXCERPT_CHARS=260
MILVUS_DENSE_DIM=1024
MILVUS_DROP_RATIO_BUILD=0.2
MILVUS_DROP_RATIO_SEARCH=0.15
MILVUS_CHUNK_TEXT_MAX_LENGTH=8192
MILVUS_UPSERT_BATCH_SIZE=512
MILVUS_DELETE_BATCH_SIZE=64
MILVUS_RRF_K=60
MILVUS_HYBRID_DENSE_WEIGHT=0.65
MILVUS_HYBRID_SPARSE_WEIGHT=0.35
MILVUS_QUERY_CACHE_SIZE=64
HYBRID_SEMANTIC_HEAD_LIMIT=16
SEARCH_RERANK_TOP_K=12
SEARCH_RERANK_MAX_TEXT_CHARS=1200
SEARCH_KEYWORD_MIN_SCORE=20
SEARCH_SEMANTIC_MIN_SCORE=0.2
SEARCH_HYBRID_MIN_SCORE=0.2
SEARCH_KEYWORD_RELATIVE_CUTOFF=0.0
SEARCH_SEMANTIC_RELATIVE_CUTOFF=0.35
SEARCH_HYBRID_RELATIVE_CUTOFF=0.4
SEARCH_METADATA_ONLY_SCORE_FACTOR=0.88
SEARCH_FULLTEXT_SCORE_BONUS=0.03
INGESTION_MIN_TEXT_CHARS=120
INGESTION_MIN_TEXT_WORDS=25
UPLOAD_PREFILL_CONTENTS_MAX_CHARS=700
SEARCH_REFERENCE_CHUNK_SCORE_FACTOR=0.08
SEARCH_CROSS_SCRIPT_SCORE_FACTOR=0.42
SEARCH_ZERO_OVERLAP_CROSS_SCRIPT_FACTOR=0.30
SEARCH_TOKEN_COVERAGE_BOOST=0.18
SEARCH_TOC_CHUNK_SCORE_FACTOR=0.04
SEARCH_ZERO_GROUNDING_SCORE_FACTOR=0.26
SEARCH_HYBRID_ZERO_GROUNDING_SCORE_FACTOR=0.16
SEARCH_PARTIAL_GROUNDING_SCORE_FACTOR=0.72
SEARCH_EXACT_QUERY_GROUNDING_BOOST=0.18
SEARCH_HYBRID_SEMANTIC_BLEND=0.58
SEARCH_HYBRID_KEYWORD_BLEND=0.42
SEARCH_HYBRID_SEMANTIC_ONLY_FACTOR=0.58
SEARCH_SEMANTIC_EXACT_PHRASE_BOOST=0.32
SEARCH_HYBRID_EXACT_PHRASE_BOOST=0.44
VECTOR_CHUNK_MIN_INDEX_QUALITY=0.28
VECTOR_CHUNK_MIN_INFORMATION_DENSITY=0.24
SEARCH_BENCHMARK_RUNS=3
SEARCH_BENCHMARK_TOP_K=5
SEARCH_BENCHMARK_LIMIT=20
SEARCH_BENCHMARK_OUTPUT_DIR=/app/var/search_benchmarks
SEARCH_WARMUP_RUN_QUERY=True
SEARCH_WARMUP_SAMPLE_QUERY=поиск
HEALTHCHECK_CHECK_VECTOR_STORE=True
HEALTHCHECK_REQUIRE_WARMUP=True

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

RECOMMENDATION_HISTORY_LIMIT=5
RECOMMENDATION_PER_QUERY_LIMIT=16
RECOMMENDATION_MAX_RESULTS=50
RECOMMENDATION_RECENCY_DECAY=0.78
RECOMMENDATION_RELATIVE_FLOOR=0.4
RECOMMENDATION_VIEWED_FACTOR=0.78
RECOMMENDATION_DOWNLOADED_FACTOR=0.45
RECOMMENDATION_KEYWORD_FALLBACK_LIMIT=4
RECOMMENDATION_CACHE_TIMEOUT=300
RECOMMENDATION_PRELOAD_PAGES=2
RECOMMENDATION_ENTRY_CACHE_SEARCH_LIMIT=2
USER_ACTIVITY_VIEW_DEBOUNCE_MINUTES=30
