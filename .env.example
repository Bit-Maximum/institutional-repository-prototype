DEBUG=True
SECRET_KEY=change-me
ALLOWED_HOSTS=127.0.0.1,localhost
DATABASE_URL=postgresql://repository:repository@localhost:5432/repository
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=publications_chunks_hybrid_v1
MILVUS_BGE_M3_MODEL=BAAI/bge-m3
MILVUS_BGE_M3_BATCH_SIZE=24
MILVUS_BGE_M3_DEVICE=auto
MILVUS_BGE_M3_USE_FP16=True
SEARCH_RERANK_DEVICE=auto
MILVUS_DENSE_DIM=1024
MILVUS_DROP_RATIO_BUILD=0.2
MILVUS_DROP_RATIO_SEARCH=0.15
MILVUS_CHUNK_TEXT_MAX_LENGTH=8192
MILVUS_UPSERT_BATCH_SIZE=128
MILVUS_DELETE_BATCH_SIZE=64
MILVUS_RRF_K=60
MILVUS_HYBRID_DENSE_WEIGHT=0.65
MILVUS_HYBRID_SPARSE_WEIGHT=0.35
MEDIA_ROOT=media
STATIC_ROOT=staticfiles

WAGTAILADMIN_BASE_URL=http://localhost:8000

VECTOR_INDEX_SCHEMA_VERSION=2026-03-fast-batch-v1
VECTOR_CHUNK_MAX_WORDS=320
VECTOR_CHUNK_OVERLAP_WORDS=40
VECTOR_CHUNK_MAX_CHARS=2200
VECTOR_INDEX_MAX_EMBED_TEXTS=128
VECTOR_REINDEX_PUBLICATION_BATCH_SIZE=24

SEARCH_PAGE_SIZE=10
SEARCH_CANDIDATE_POOL_SIZE=120
SEARCH_EXCERPT_CHARS=260

SEARCH_PROFILE=fast
MILVUS_CHUNK_CANDIDATE_POOL=60
HYBRID_SEMANTIC_HEAD_LIMIT=16
SEARCH_RERANK_ENABLED=False
SEARCH_RERANK_MODEL=BAAI/bge-reranker-v2-m3
SEARCH_RERANK_TOP_K=12
SEARCH_RERANK_MAX_TEXT_CHARS=1200
MILVUS_QUERY_CACHE_SIZE=64
SEARCH_KEYWORD_MIN_SCORE=20
SEARCH_SEMANTIC_MIN_SCORE=0.2
SEARCH_HYBRID_MIN_SCORE=0.2
INGESTION_MIN_TEXT_CHARS=120
INGESTION_MIN_TEXT_WORDS=25
UPLOAD_PREFILL_CONTENTS_MAX_CHARS=700
SEARCH_METADATA_ONLY_SCORE_FACTOR=0.88
SEARCH_FULLTEXT_SCORE_BONUS=0.03

# Semantic-search quality controls
VECTOR_CHUNK_MIN_INDEX_QUALITY=0.28
SEARCH_REFERENCE_CHUNK_SCORE_FACTOR=0.08
SEARCH_CROSS_SCRIPT_SCORE_FACTOR=0.42
SEARCH_ZERO_OVERLAP_CROSS_SCRIPT_FACTOR=0.30
SEARCH_TOKEN_COVERAGE_BOOST=0.18

SEARCH_TOC_CHUNK_SCORE_FACTOR=0.04
SEARCH_ZERO_GROUNDING_SCORE_FACTOR=0.26
SEARCH_HYBRID_ZERO_GROUNDING_SCORE_FACTOR=0.16
SEARCH_PARTIAL_GROUNDING_SCORE_FACTOR=0.72
SEARCH_EXACT_QUERY_GROUNDING_BOOST=0.18

SEARCH_HYBRID_SEMANTIC_BLEND=0.58
SEARCH_HYBRID_KEYWORD_BLEND=0.42
SEARCH_HYBRID_SEMANTIC_ONLY_FACTOR=0.58
SEARCH_SEMANTIC_EXACT_PHRASE_BOOST=0.32
SEARCH_HYBRID_EXACT_PHRASE_BOOST=0.44

SEARCH_KEYWORD_RELATIVE_CUTOFF=0.0
SEARCH_SEMANTIC_RELATIVE_CUTOFF=0.35
SEARCH_HYBRID_RELATIVE_CUTOFF=0.4
SEARCH_WARMUP_ON_STARTUP=True
SEARCH_WARMUP_INCLUDE_RERANK=False
SEARCH_WARMUP_LOAD_COLLECTION=True

SEARCH_BENCHMARK_RUNS=3
SEARCH_BENCHMARK_TOP_K=5
SEARCH_BENCHMARK_LIMIT=20
SEARCH_BENCHMARK_OUTPUT_DIR=var/search_benchmarks
